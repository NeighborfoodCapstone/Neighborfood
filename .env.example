# NeighborFood — 환경변수 템플릿
# 이 파일을 복사해 .env 로 저장하고, 실제 값을 채워 주세요.
# .env 파일은 .gitignore에 포함되므로 GitHub에 올라가지 않습니다.
#
# 사용법:
#   Windows : copy .env.example .env
#   Mac/Linux: cp .env.example .env

# ── CLOVA OCR (없으면 Tesseract fallback 또는 빈 결과) ──────────────────
CLOVA_OCR_INVOKE_URL=   # CLOVA OCR 콘솔에서 발급한 Invoke URL
CLOVA_OCR_SECRET=       # CLOVA OCR 콘솔에서 발급한 Secret Key

# ── 카카오 지도 JS API 키 ─────────────────────────────────────────────────
# 발급: https://developers.kakao.com → 내 애플리케이션 → 앱 키 → JavaScript 키
# 주의: 카카오 개발자 콘솔에서 허용 도메인에 아래 항목을 반드시 등록하세요.
#        로컬 : http://127.0.0.1:8000
#        배포 : https://your-domain.com
KAKAO_JS_KEY=your_kakao_js_key_here
